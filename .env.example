# This env file describes the canonical app/sql runtime shape.
# Do not reinterpret it as permission to create a second domain SQL truth
# on the operator IDE machine when the accepted runtime lives on the VM.
PORT=3000
DATABASE_URL=postgresql://ecostroycontinent:change-me@sql:5432/ecostroycontinent
POSTGRES_DB=ecostroycontinent
POSTGRES_USER=ecostroycontinent
POSTGRES_PASSWORD=change-me
APP_IMAGE=ghcr.io/kwentin3/ecostroycontinent-app:latest
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=ecostroy_admin_session
SESSION_TTL_HOURS=24
MEDIA_STORAGE_MODE=local
MEDIA_STORAGE_DIR=var/media
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=ru-3
MEDIA_S3_ENDPOINT_URL=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_PUBLIC_BASE_URL=
# LLM runtime config: Gemini 3 Flash
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash
LLM_GEMINI_API_KEY=
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# LLM transport config: SOCKS5
LLM_SOCKS5_ENABLED=true
LLM_SOCKS5_HOST=proxy-ip-or-hostname
LLM_SOCKS5_PORT=1080
LLM_SOCKS5_USERNAME=
LLM_SOCKS5_PASSWORD=
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=change-me-superadmin
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_DISPLAY_NAME=System Superadmin
BOOTSTRAP_SUPERADMIN_ACCESS_TOKEN=change-me-bootstrap-authority
SEED_SEO_USERNAME=seo
SEED_SEO_PASSWORD=change-me-seo
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=change-me-owner
